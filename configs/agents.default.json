    },
    {
      "id": "long-context-reader",
      "role": "analysis",
      "modelPreference": ["minimax-token-plan/MiniMax-M3"],
      "tools": "read-only"
    },
    {
      "id": "completion-skeptic",
      "role": "judge",
      "modelPreference": ["nvidia-build-nim/nvidia/nemotron-3-ultra-550b-a55b", "stepfun-step-plan/step-3.7-flash"],
      "tools": "read-only"
    }
  ],
  "mandatoryRules": {
    "seriousCodeTaskRequiresSubagents": true,
    "goalCompletionRequiresTwoReviewPasses": true,
    "katRequiresStepfunCompanion": true,
    "providerFailureRequiresReplacement": true
  }
}
