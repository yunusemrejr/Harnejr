{
  "version": 1,
  "agents": [
    {
      "id": "primary-engineer",
      "role": "main",
      "modelPreference": ["deepseek-api/deepseek-v4-flash", "kimi-code-subscription/kimi-for-coding"],
      "tools": "workspace-safe"
    },
    {
      "id": "stepfun-verifier",
      "role": "reviewer",
      "modelPreference": ["stepfun-step-plan/step-3.7-flash"],
      "tools": "read-only"
    },
    {
      "id": "kat-coder",
      "role": "implementation",
      "modelPreference": ["streamlake-kat-coding-plan/kat-coder-pro-v2"],
      "tools": "workspace-safe",
