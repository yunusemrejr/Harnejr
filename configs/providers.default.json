{
  "version": 1,
  "providers": [
    {
      "id": "deepseek-api",
      "displayName": "DeepSeek API",
      "enabled": true,
      "protocol": "openai_chat",
      "runtime": "raw_http",
      "billingMode": "api",
      "baseURL": "https://api.deepseek.com/v1",
      "endpoint": "/chat/completions",
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "authMode": "bearer",
      "defaultModel": "deepseek-v4-flash",
      "models": [
        {
          "id": "deepseek-v4-flash",
          "displayName": "DeepSeek v4 Flash",
          "contextWindow": 1000000,
          "maxOutputTokens": 32768,
          "supportsTools": true,
          "supportsReasoning": false,
          "supportsPromptCache": true,
          "supportsStreaming": true,
          "costClass": "cheap"
        },
        {
          "id": "deepseek-v4-pro",
          "displayName": "DeepSeek v4 Pro",
          "contextWindow": 1000000,
          "maxOutputTokens": 32768,
          "supportsTools": true,
          "supportsReasoning": true,
          "supportsPromptCache": true,
          "supportsStreaming": true,
          "costClass": "medium"
        }
      ],
      "reasoningAdapter": "deepseek",
      "streamingParser": "openai_sse",
      "timeoutMs": 120000,
      "maxRetries": 2,
      "notes": "Direct API billing. Keep separate from aggregator routes."
    },
    {
      "id": "stepfun-step-plan",
      "displayName": "StepFun Step Plan",
      "enabled": true,
      "protocol": "openai_chat",
      "runtime": "raw_http",
      "billingMode": "subscription",
      "baseURL": "https://api.stepfun.ai/step_plan/v1",
      "endpoint": "/chat/completions",
      "apiKeyEnv": "STEPFUN_API_KEY",
      "authMode": "bearer",
      "defaultModel": "step-3.7-flash",
      "models": [
        {
          "id": "step-3.7-flash",
          "displayName": "StepFun 3.7 Flash",
          "contextWindow": 128000,
          "maxOutputTokens": 32768,
          "supportsTools": true,
          "supportsReasoning": true,
          "supportsStreaming": true,
          "costClass": "cheap"
        }
      ],
      "reasoningAdapter": "stepfun_openai",
      "streamingParser": "openai_sse",
      "timeoutMs": 120000,
      "maxRetries": 2,
      "notes": "Preferred frequent verifier and mandatory KAT companion. Do not silently fall back to the normal StepFun /v1 billing path."
    },
    {
      "id": "streamlake-kat-coding-plan",
      "displayName": "StreamLake KAT Coding Plan",
      "enabled": true,
      "protocol": "openai_chat",
      "runtime": "raw_http",
      "billingMode": "subscription",
      "baseURL": "https://wanqing.streamlakeapi.com/api/gateway/coding/v1",
      "endpoint": "/chat/completions",
      "apiKeyEnv": "STREAMLAKE_API_KEY",
      "authMode": "bearer",
      "defaultModel": "kat-coder-pro-v2",
      "models": [
        {
          "id": "kat-coder-pro-v2",
          "displayName": "KAT Coder Pro V2",
          "contextWindow": 256000,
          "maxOutputTokens": 32768,
          "supportsTools": true,
          "supportsReasoning": true,
          "supportsStreaming": true,
          "costClass": "medium"
        }
      ],
      "reasoningAdapter": "none",
      "streamingParser": "openai_sse",
      "timeoutMs": 180000,
      "maxRetries": 1,
      "notes": "Coding-plan model namespace. KAT usage must schedule StepFun companion verification."
    },
    {
      "id": "minimax-token-plan",
      "displayName": "MiniMax Token Plan",
      "enabled": true,
      "protocol": "openai_chat",
      "runtime": "raw_http",
      "billingMode": "subscription",
      "baseURL": "https://api.minimax.io/v1",
      "endpoint": "/chat/completions",
      "apiKeyEnv": "MINIMAX_API_KEY",
      "authMode": "bearer",
      "defaultModel": "MiniMax-M3",
      "models": [
        {
          "id": "MiniMax-M3",
          "displayName": "MiniMax M3",
          "contextWindow": 1000000,
          "maxOutputTokens": 32768,
          "supportsTools": true,
          "supportsVision": true,
          "supportsReasoning": true,
          "supportsStreaming": true,
          "costClass": "medium"
        }
      ],
      "requestDefaults": {
        "thinking": { "type": "adaptive" },
        "reasoning_split": true
      },
      "reasoningAdapter": "minimax_m3",
      "streamingParser": "minimax_sse",
      "timeoutMs": 180000,
      "maxRetries": 1,
      "notes": "Long-context analysis provider. Token Plan must stay separate from pay-as-you-go MiniMax routes."
    },
    {
      "id": "kimi-code-subscription",
      "displayName": "Kimi Code Subscription",
